{
  "name": "vibe-switch",
  "version": "1.0.2",
  "description": "tmux for AI Agents — Orchestrate multiple AI coding agents in parallel with one command",
  "main": "dist/cli.js",
  "bin": {
    "vibe": "./dist/cli.js"
  },
  "scripts": {
