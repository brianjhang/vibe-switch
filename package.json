  },
  "repository": {
    "type": "git",
    "url": "https://github.com/brianjhang/vibe-switch"
  },
  "type": "commonjs",
  "dependencies": {
    "chalk": "^5.6.2",
    "cli-table3": "^0.6.5",
    "commander": "^14.0.3",
    "simple-git": "^3.35.2",
    "typescript": "^6.0.2"
  },
  "devDependencies": {
